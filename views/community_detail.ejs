<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <title>글 상세보기 - 공공재 커뮤니티</title>
    <link rel="stylesheet" href="../css/community_detail.css" />
  </head>
  <body>
    <div class="container">
      <!-- 사이드바 -->
      <aside class="sidebar">
        <div class="logo-area">
          <img src="../reallogo 1.png" alt="공공재 로고" class="logo" />
        </div>
        <button class="btn login">로그인</button>
        <button class="btn signup">회원가입</button>
      </aside>

      <!-- 메인 콘텐츠 -->
      <main class="main-content">
        <header class="title-wrapper">
          <h1 class="page-title"><strong>Community</strong></h1>
        </header>

        <div class="divider"></div>

        <section class="post-detail">
          <h2 class="post-title"><%= post.title %></h2>
          <div class="post-meta">
            <span class="category">#<%= post.category %></span>
            <span class="author">작성자: <%= post.author %></span>
            <span class="date"
              ><%= post.createdAt.toISOString().slice(0,10) %></span
            >
          </div>

          <div class="post-image">
            <% if (post.image) { %>
            <img
              src="<%= post.image %>"
              alt="첨부 이미지"
              style="max-width: 100%; height: auto; margin: 10px 0"
            />
            <% } %>
          </div>

          <div class="post-content">
            <p><%= post.content %></p>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
